{
  "name": "teklifim-frontend",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,jsx}\" \"e2e/**/*.js\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e:install": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright install chromium",
    "e2e": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test",
    "e2e:headed": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test --headed",
    "quality:gate": "npm run lint && npm run test:run && npm run build",
    "quality:e2e": "E2E_BACKEND_PORT=4011 E2E_FRONTEND_PORT=5201 npm run e2e"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@playwright/test": "^1.54.2",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
